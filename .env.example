# ─────────────────────────────────────────────────────────────
#  Salon Janika — environment variables
#  Copy to ".env" and fill in. NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────

# Canonical public URL of the deployed site (no trailing slash).
SITE_URL="https://salonjanika.fi"

# ── Supabase ──────────────────────────────────────────────────
# Project URL + anon key are safe to expose to the browser (PUBLIC_ prefix).
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Service-role key bypasses RLS. SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# ── Resend (transactional email) ──────────────────────────────
# Create a key at https://resend.com and verify your sending domain.
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxx"
# Must be on a verified domain, e.g. "Salon Janika <varaukset@salonjanika.fi>"
RESEND_FROM="Salon Janika <varaukset@salonjanika.fi>"

# The owner's inbox that receives new booking-request notifications.
OWNER_EMAIL="janika@salonjanika.fi"

# NOTE: The site runs WITHOUT these set — public pages fall back to the
# seeded Finnish defaults and the booking form logs instead of emailing.
# This makes local `npm run dev` work out of the box for previewing the design.
