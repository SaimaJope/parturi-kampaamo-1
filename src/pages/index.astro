---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionTitle from '../components/SectionTitle.astro';
import Reveal from '../components/Reveal.astro';
import Gallery from '../components/Gallery.astro';
import { getContent, c, getGallery } from '../lib/content';

const content = await getContent();
const gallery = await getGallery();

const telHref = 'tel:+358' + c(content, 'phone').replace(/\D/g, '').replace(/^0/, '');
---

<BaseLayout
  title="Salon Janika — Parturi-kampaamo Matinkylä, Espoo"
  description="Koko perheen parturi-kampaamo Espoon Matinkylässä. Leikkaukset, värit, permanentit ja Olaplex-hoidot laadukkailla Wella-aineilla. Varaa aika helposti."
  path="/"
  transparentHeader
>
  <!-- ───────────── HERO ───────────── -->
  <section class="relative h-[100svh] min-h-[600px] flex items-center justify-center overflow-hidden">
    <div class="absolute inset-0">
      <img
        src="/images/hero.jpg"
        alt="Hiusten muotoilua Salon Janikassa"
        class="w-full h-full object-cover ken-burns photo"
        fetchpriority="high"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-ink/55 via-ink/40 to-ink/75"></div>
    </div>

    <div class="relative z-10 text-center px-6 text-cream">
      <p class="eyebrow !text-cream/80 mb-6 reveal is-visible">Parturi-Kampaamo · Matinkylä, Espoo</p>
      <h1 class="leading-[0.82]">
        <span class="script block text-gold-soft" style="font-size:var(--text-hero)">Salon</span>
        <span class="font-serif block text-cream tracking-tight" style="font-size:clamp(2.5rem,9vw,6.5rem)">Janika</span>
      </h1>
      <p class="mt-7 max-w-xl mx-auto text-cream/85 text-lg font-light">
        {c(content, 'hero_tagline')}
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/ajanvaraus" class="btn btn-light">Varaa aika</a>
        <a href="/hinnasto" class="btn btn-outline !border-cream/70 !text-cream hover:!bg-cream hover:!text-ink">Hinnasto</a>
      </div>
    </div>

    <!-- scroll cue -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10 text-cream/70">
      <span class="block w-px h-12 bg-cream/50 mx-auto animate-pulse"></span>
    </div>
  </section>

  <!-- ───────────── INTRO / ABOUT ───────────── -->
  <section class="py-24 md:py-36">
    <div class="container-wide grid gap-14 md:gap-20 md:grid-cols-2 items-center">
      <Reveal class="order-2 md:order-1">
        <span class="eyebrow">Tervetuloa</span>
        <h2 class="font-serif mt-5 leading-[1.05]" style="font-size:var(--text-display)">
          Rauhallinen hetki <span class="script block text-[1.2em] leading-none mt-1">sinulle</span>
        </h2>
        <p class="mt-8 text-lg text-ink-soft leading-relaxed max-w-prose">
          {c(content, 'etusivu_body')}
        </p>
        <div class="rule max-w-[8rem] my-9"></div>
        <a href="/ajanvaraus" class="btn btn-outline">Varaa aika</a>
      </Reveal>

      <Reveal class="order-1 md:order-2" delay={120}>
        <div class="relative aspect-[4/5] overflow-hidden">
          <img src="/images/about.jpg" alt="Kiharoiden muotoilua Salon Janikassa" loading="lazy" class="w-full h-full object-cover photo" />
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ───────────── FULL-BLEED QUOTE / WELLA ───────────── -->
  <section class="relative py-28 md:py-40 bg-ink text-cream overflow-hidden">
    <div class="container-prose text-center relative z-10">
      <Reveal>
        <span class="script text-gold-soft" style="font-size:clamp(3rem,8vw,5rem)">Laatua</span>
        <p class="font-serif text-2xl md:text-4xl leading-snug mt-4 max-w-3xl mx-auto text-cream/90">
          Käytän väreissä ja kiharoissa laadukkaita Wella-aineita.
        </p>
        <a href="/hinnasto" class="btn btn-light mt-12">Katso palvelut</a>
      </Reveal>
    </div>
  </section>

  <!-- ───────────── CONTACT BLOCK ───────────── -->
  <section class="py-24 md:py-32">
    <div class="container-wide grid gap-14 md:grid-cols-2 items-center">
      <Reveal>
        <div class="relative aspect-[5/4] overflow-hidden">
          <img src="/images/contact.jpg" alt="Salon Janikan rauhallinen sisätila" loading="lazy" class="w-full h-full object-cover photo" />
        </div>
      </Reveal>
      <Reveal delay={120} class="md:pl-6">
        <SectionTitle eyebrow="Käy kylässä" script="Tervetuloa" title="" align="left" />
        <address class="not-italic mt-8 space-y-5 text-lg text-ink-soft">
          <p>
            <a href={telHref} class="hover:text-gold transition-colors">{c(content, 'phone_display')}</a>
          </p>
          <p>
            {c(content, 'address_street')}<br />
            {c(content, 'address_postal')}
          </p>
          <p class="text-base">{c(content, 'open_weekday')} · {c(content, 'open_saturday')}</p>
        </address>
        <div class="mt-10 flex gap-4">
          <a href="/yhteystiedot" class="btn btn-outline">Yhteystiedot</a>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- ───────────── GALLERY ───────────── -->
  <section class="pb-4">
    <div class="container-wide text-center mb-10">
      <SectionTitle eyebrow="Galleria" script="Salon Janika" title="" />
    </div>
    <Gallery images={gallery} />
  </section>
</BaseLayout>
