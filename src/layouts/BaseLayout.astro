---
/**
 * BaseLayout — shared <head>, fonts, SEO, JSON-LD, header + footer.
 * Public pages are SSR (output: 'server'); content is read per request.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getContent, c } from '../lib/content';

export interface Props {
  title: string;
  description: string;
  /** Path for canonical/OG URL, e.g. "/hinnasto". Defaults to current path. */
  path?: string;
  ogImage?: string;
  /** Set false on admin pages to drop the public header/footer. */
  chrome?: boolean;
  /** Include the LocalBusiness/HairSalon JSON-LD (true on public pages). */
  schema?: boolean;
  /** Transparent white header over a dark hero (homepage), solid on scroll. */
  transparentHeader?: boolean;
}

const {
  title,
  description,
  path,
  ogImage = '/images/og-default.svg',
  chrome = true,
  schema = true,
  transparentHeader = false,
} = Astro.props;

const site = import.meta.env.SITE_URL || Astro.site?.toString() || 'http://localhost:4321';
const siteBase = site.replace(/\/$/, '');
const canonical = new URL(path ?? Astro.url.pathname, siteBase + '/').toString();
const ogImageUrl = ogImage.startsWith('http') ? ogImage : siteBase + ogImage;

const content = await getContent();
const phone = c(content, 'phone');
const phoneDisplay = c(content, 'phone_display');

// JSON-LD: HairSalon / LocalBusiness
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HairSalon',
  name: 'Salon Janika',
  description:
    'Koko perheen parturi-kampaamo Espoon Matinkylässä. Leikkaukset, värit, permanentit ja Olaplex-hoidot laadukkailla Wella-aineilla.',
  image: ogImageUrl,
  url: siteBase + '/',
  telephone: '+358' + phone.replace(/\D/g, '').replace(/^0/, ''),
  priceRange: '€€',
  currenciesAccepted: 'EUR',
  address: {
    '@type': 'PostalAddress',
    streetAddress: c(content, 'address_street'),
    postalCode: '02230',
    addressLocality: 'Espoo',
    addressRegion: 'Uusimaa',
    addressCountry: 'FI',
  },
  geo: {
    '@type': 'GeoCoordinates',
    // TODO: replace with exact coordinates for Mirjankuja 2 if needed.
    latitude: 60.1605,
    longitude: 24.7385,
  },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
      opens: '10:00',
      closes: '18:00',
    },
  ],
  // TODO: add real social profile URLs.
  sameAs: [] as string[],
};
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Salon Janika" />
    <meta property="og:locale" content="fi_FI" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="theme-color" content="#1c1a17" />

    <!-- Fonts: preconnect + single stylesheet (display=swap) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&family=Pinyon+Script&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,400&family=Jost:wght@300;400;500&family=Pinyon+Script&display=swap"
    />

    {schema && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(jsonLd)}
      />
    )}
  </head>
  <body>
    {chrome && <Header phone={phone} phoneDisplay={phoneDisplay} transparentTop={transparentHeader} />}
    <main id="main">
      <slot />
    </main>
    {chrome && (
      <Footer
        hours={c(content, 'footer_hours')}
        phoneDisplay={phoneDisplay}
        phone={phone}
        addressStreet={c(content, 'address_street')}
        addressArea={c(content, 'address_area')}
      />
    )}

    <!-- Scroll-reveal: progressive enhancement, reduced-motion safe -->
    <script>
      const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const els = document.querySelectorAll('.reveal');
      if (prefersReduced || !('IntersectionObserver' in window)) {
        els.forEach((el) => el.classList.add('is-visible'));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                (e.target as HTMLElement).classList.add('is-visible');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
