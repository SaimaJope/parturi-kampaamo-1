---
/**
 * AdminLayout — minimal chrome for the protected /admin area (Finnish UI).
 * Does NOT include the public header/footer. Pages must call requireAdmin()
 * themselves before rendering.
 */
import '../styles/global.css';

export interface Props {
  title: string;
  email?: string;
  active?: 'bookings' | 'content';
}
const { title, email, active } = Astro.props;
const tab = (key: string) =>
  active === key
    ? 'text-ink border-gold'
    : 'text-ink-soft/60 border-transparent hover:text-ink';
---

<!doctype html>
<html lang="fi">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Salon Janika</title>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Jost:wght@300;400;500&family=Pinyon+Script&display=swap"
    />
  </head>
  <body class="bg-cream min-h-screen">
    <header class="border-b border-taupe-deep/20 bg-soft">
      <div class="container-wide flex items-center justify-between py-4">
        <a href="/admin" class="font-serif text-xl">
          Salon <span class="script text-2xl">Janika</span>
          <span class="eyebrow ml-3 !text-[0.6rem]">Hallinta</span>
        </a>
        <div class="flex items-center gap-5">
          <a href="/" class="eyebrow !text-[0.62rem] hover:text-ink">Sivusto ↗</a>
          {email && (
            <>
              <span class="hidden sm:inline text-xs text-ink-soft/60">{email}</span>
              <form method="POST" action="/api/auth/logout">
                <button class="eyebrow !text-[0.62rem] hover:text-ink" type="submit">Kirjaudu ulos</button>
              </form>
            </>
          )}
        </div>
      </div>
      {active && (
        <div class="container-wide flex gap-8">
          <a href="/admin" class:list={['py-3 -mb-px border-b-2 eyebrow !text-[0.66rem]', tab('bookings')]}>
            Varauspyynnöt
          </a>
          <a href="/admin/sisalto" class:list={['py-3 -mb-px border-b-2 eyebrow !text-[0.66rem]', tab('content')]}>
            Sisältö
          </a>
        </div>
      )}
    </header>

    <main class="container-wide py-10">
      <slot />
    </main>
  </body>
</html>
